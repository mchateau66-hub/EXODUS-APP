generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String               @id @default(uuid())
  email                   String               @unique
  role                    Role
  stripe_customer_id      String?              @unique
  status                  UserStatus           @default(active)
  created_at              DateTime             @default(now())
  updated_at              DateTime             @updatedAt
  deleted_at              DateTime?
  onboardingStep          Int                  @default(0)
  onboardingStep1Answers  Json?
  coachQualificationScore Int                  @default(0)
  onboardingStep2Answers  Json?
  name                    String?
  age                     Int?
  avatarUrl               String?
  bio                     String?
  country                 String?
  keywords                String[]             @default([])
  language                String?
  theme                   String?              @default("light")
  passwordHash            String?
  athleteProfile          AthleteProfile?
  auditLogs               AuditLog[]
  coach                   Coach?               @relation("UserCoach")
  coachAthletes           CoachAthlete[]
  reviewedCoachDocuments  CoachDocument[]      @relation("CoachDocReviewer")
  coachDocuments          CoachDocument[]
  devices                 Device[]
  messages                Message[]
  passwordResetTokens     PasswordResetToken[]
  sessions                Session[]
  subscriptions           Subscription[]
  trainingPlans           TrainingPlan[]
  usageCounters           UsageCounter[]
  /** Compteurs agrégés V1 (usage tracking produit, distinct des UsageCounter par feature/période) */
  usageAggregate          UserUsageCounter?
  entitlements            UserEntitlement[]
  athleteAds              AthleteAd[]

  @@index([role])
}

/// Compteurs d’usage par utilisateur (V1 mesure — pas d’enforcement quota ici).
/// Jour « courant » : date UTC (YYYY-MM-DD) pour `messages_sent_today` / `daily_reset_at`.
model UserUsageCounter {
  user_id               String    @id
  messages_sent_today   Int       @default(0)
  messages_sent_total   Int       @default(0)
  coach_profile_views   Int       @default(0)
  search_result_views   Int       @default(0)
  contact_unlocks       Int       @default(0)
  daily_reset_at        DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt
  user                  User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_usage_counters")
}

model PasswordResetToken {
  id         String    @id @default(uuid())
  user_id    String
  token_hash String    @unique
  expires_at DateTime
  created_at DateTime  @default(now())
  used_at    DateTime?
  user       User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([expires_at])
}

model Coach {
  id            String         @id @default(uuid())
  slug          String         @unique
  name          String
  subtitle      String?
  avatarInitial String?
  created_at    DateTime       @default(now())
  updated_at    DateTime       @updatedAt
  user_id       String?        @unique
  user          User?          @relation("UserCoach", fields: [user_id], references: [id])
  coachAthletes CoachAthlete[]
  messages      Message[]

  @@index([slug])
}

model AthleteProfile {
  id               String   @id @default(uuid())
  user_id          String   @unique
  goalType         String
  customGoal       String?
  timeframe        String
  experienceLevel  String
  context          String
  objectiveSummary String
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt
  user             User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

model Plan {
  key                     String         @id
  name                    String
  active                  Boolean        @default(true)
  stripe_price_id_monthly String?
  stripe_price_id_yearly  String?
  created_at              DateTime       @default(now())
  features                PlanFeature[]
  subscriptions           Subscription[]
}

model Feature {
  key          String            @id
  description  String
  plans        PlanFeature[]
  counters     UsageCounter[]
  entitlements UserEntitlement[]
}

model CoachAthlete {
  coach_id       String
  athlete_id     String
  status         CoachAthleteStatus @default(LEAD)
  labels         String[]           @default([])
  nextFollowUpAt DateTime?
  lastMessageAt  DateTime?
  pinned         Boolean            @default(false)
  created_at     DateTime           @default(now())
  updated_at     DateTime           @updatedAt
  athlete        User               @relation(fields: [athlete_id], references: [id])
  coach          Coach              @relation(fields: [coach_id], references: [id])

  @@id([coach_id, athlete_id])
  @@index([coach_id, status, nextFollowUpAt])
}

model PlanFeature {
  plan_key    String
  feature_key String
  feature     Feature @relation(fields: [feature_key], references: [key], onDelete: Cascade)
  plan        Plan    @relation(fields: [plan_key], references: [key], onDelete: Cascade)

  @@id([plan_key, feature_key])
}

model Subscription {
  id                     String            @id @default(uuid())
  user_id                String
  plan_key               String?
  stripe_customer_id     String?
  stripe_subscription_id String            @unique
  status                 SubStatus
  current_period_start   DateTime?
  current_period_end     DateTime?
  cancel_at_period_end   Boolean           @default(false)
  canceled_at            DateTime?
  trial_end_at           DateTime?
  created_at             DateTime          @default(now())
  updated_at             DateTime          @updatedAt
  expires_at             DateTime?
  plan                   Plan?             @relation(fields: [plan_key], references: [key])
  user                   User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  entitlements           UserEntitlement[]
  billing                BillingPeriod?

  @@index([user_id])
  @@index([status])
}

model UserEntitlement {
  id              String        @id @default(uuid())
  user_id         String
  feature_key     String
  source          Source
  subscription_id String?
  starts_at       DateTime      @default(now())
  expires_at      DateTime?
  meta            Json          @default("{}")
  created_at      DateTime      @default(now())
  feature         Feature       @relation(fields: [feature_key], references: [key], onDelete: Cascade)
  subscription    Subscription? @relation(fields: [subscription_id], references: [id])
  user            User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, feature_key])
}

model Session {
  id           String    @id @default(uuid())
  user_id      String
  created_at   DateTime  @default(now())
  last_seen_at DateTime?
  ip_hash      String?
  ua_hash      String?
  user         User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model Device {
  id          String    @id @default(uuid())
  user_id     String
  first_seen  DateTime  @default(now())
  last_seen   DateTime?
  fingerprint String?
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
}

model UsageCounter {
  user_id      String
  feature_key  String
  period_start DateTime
  count        Int      @default(0)
  feature      Feature  @relation(fields: [feature_key], references: [key], onDelete: Cascade)
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, feature_key, period_start])
}

model AuditLog {
  id         String   @id @default(uuid())
  user_id    String?
  action     String
  meta       Json     @default("{}")
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])

  @@index([user_id])
}

model TrainingPlan {
  id         String            @id @default(uuid())
  user_id    String
  title      String
  start_date DateTime
  end_date   DateTime
  created_at DateTime          @default(now())
  updated_at DateTime          @updatedAt
  user       User              @relation(fields: [user_id], references: [id], onDelete: Cascade)
  sessions   TrainingSession[]

  @@index([user_id])
}

model TrainingSession {
  id           String                @id @default(uuid())
  plan_id      String
  date         DateTime
  label        String
  focus        String?
  duration_min Int?
  created_at   DateTime              @default(now())
  updated_at   DateTime              @updatedAt
  status       TrainingSessionStatus @default(planned)
  plan         TrainingPlan          @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@index([plan_id, date])
}

model Message {
  id         String   @id @default(uuid())
  user_id    String
  content    String
  created_at DateTime @default(now())
  coach_id   String?
  coach      Coach?   @relation(fields: [coach_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@index([coach_id, created_at])
}

/// *
/// * ✅ CoachDocument: diplômes / certifications + statut de vérification
model CoachDocument {
  id          String         @id @default(uuid())
  user_id     String
  kind        CoachDocKind
  title       String?
  url         String
  pathname    String
  mime_type   String
  size_bytes  Int
  status      CoachDocStatus @default(pending)
  review_note String?
  reviewed_at DateTime?
  reviewer_id String?
  created_at  DateTime       @default(now())
  updated_at  DateTime       @updatedAt
  reviewer    User?          @relation("CoachDocReviewer", fields: [reviewer_id], references: [id])
  user        User           @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([status])
}

/// *
/// * ✅ AthleteAd (table SQL: athlete_ads)
/// * IMPORTANT: DB a "User".id en TEXT -> athlete_id = String
model AthleteAd {
  id              String    @id @default(uuid())
  athlete_id      String
  title           String
  goal            String    @default("")
  sport           String    @default("")
  keywords        Json      @default("[]")
  country         String?
  city            String?
  language        String?
  budget_min      Int?
  budget_max      Int?
  lat             Float?
  lng             Float?
  status          String    @default("active")
  published_until DateTime?
  created_at      DateTime  @default(now())
  updated_at      DateTime  @updatedAt
  athlete         User      @relation(fields: [athlete_id], references: [id], onDelete: Cascade)

  @@index([athlete_id])
  @@index([country])
  @@index([language])
  @@index([lat, lng])
  @@index([status, published_until])
  @@map("athlete_ads")
}

model sat_jti {
  jti         String    @id @db.Uuid
  user_id     String    @db.Uuid
  issued_at   DateTime  @db.Timestamptz(6)
  expires_at  DateTime  @db.Timestamptz(6)
  consumed_at DateTime? @db.Timestamptz(6)
  method      String
  path        String

  @@index([consumed_at])
  @@index([expires_at])
  @@index([user_id])
}

model StripeEvent {
  id          String   @id // event.id Stripe
  type        String
  created     Int
  livemode    Boolean
  received_at DateTime @default(now())

  @@index([type])
  @@index([created])
}

model Event {
  id         String    @id @default(cuid())
  session_id String
  user_id    String?

  event      EventName
  ts         DateTime  @default(now())

  // ✅ AJOUTE ÇA
  meta       Json      @default("{}")

  // segmentation (optionnel)
  role       String?
  offer      String?
  billing    String?

  @@index([ts])
  @@index([session_id])
  @@index([event])
  @@index([user_id])
}

enum Role {
  coach
  athlete
  admin
}

enum UserStatus {
  active
  disabled
  deleted
}

enum SubStatus {
  incomplete
  trialing
  active
  past_due
  canceled
  unpaid
}

enum Source {
  plan
  purchase
  promo
  admin
}

enum CoachAthleteStatus {
  LEAD
  ACTIVE
  TO_FOLLOW
  ENDED
}

enum TrainingSessionStatus {
  planned
  done
  skipped
}

/// *
/// * ✅ Coach documents verification
enum CoachDocKind {
  diploma
  certification
  other
}

enum CoachDocStatus {
  pending
  verified
  needs_review
  rejected
}

enum BillingPeriod {
  monthly
  yearly
}

enum EventName {
  hero_click
  pricing_click
  signup_submit
  checkout_success
  sticky_click
  finalcta_click
  checkout_start
  subscription_active
  subscription_canceled
}

